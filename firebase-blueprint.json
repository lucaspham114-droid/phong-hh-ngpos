{
  "entities": {
    "ShopBackup": {
      "title": "ShopBackup",
      "description": "Secure, full-system backup of the shop POS data managed by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Owner userId matching Firebase Auth UID"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last synchronization timestamp"
        },
        "products": {
          "type": "array",
          "description": "Products catalog array"
        },
        "inventory": {
          "type": "array",
          "description": "Inventory ledger array"
        },
        "customers": {
          "type": "array",
          "description": "Customers list array"
        },
        "suppliers": {
          "type": "array",
          "description": "Suppliers list array"
        },
        "invoices": {
          "type": "array",
          "description": "Invoices ledger array"
        },
        "importSlips": {
          "type": "array",
          "description": "Import slips records"
        },
        "staffs": {
          "type": "array",
          "description": "Registered shop staff list"
        },
        "settings": {
          "type": "object",
          "description": "Store configuration, logo theme, and receipts details"
        },
        "securityLogs": {
          "type": "array",
          "description": "Security auditing logs trail"
        }
      },
      "required": ["userId", "updatedAt"]
    }
  },
  "firestore": {
    "/shops/{userId}": {
      "schema": "ShopBackup",
      "description": "Exclusive shop POS snapshot secured by Owner user UID"
    }
  }
}
