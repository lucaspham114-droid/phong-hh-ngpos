rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Catch-All Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Security Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidShopBackup(data) {
      return data.userId is string 
        && data.userId.size() <= 128 
        && data.userId.matches('^[a-zA-Z0-9_\\-]+$')
        && data.updatedAt is string;
    }

    // 3. User isolated /shops/{userId} backup collection matching blueprint
    match /shops/{userId} {
      allow read: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidShopBackup(incoming()) 
        && incoming().userId == request.auth.uid;
      allow update: if isOwner(userId) 
        && isValidShopBackup(incoming()) 
        && incoming().userId == request.auth.uid;
    }
  }
}
